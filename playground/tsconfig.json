{
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vite/client"],
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}
