{
  "name": "fastqr",
  "version": "0.1.0",
  "description": "Rust-powered fastqr toolkit for Node.js and the browser",
  "keywords": [
    "barcode",
    "napi",
    "qr",
    "qrcode",
    "wasm"
  ],
  "homepage": "https://github.com/mates-dev/fastqr#readme",
  "bugs": {
    "url": "https://github.com/mates-dev/fastqr/issues"
  },
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mates-dev/fastqr.git",
    "directory": "npm/fastqr"
  },
  "files": [
    "browser.d.ts",
    "browser.js",
    "node.js",
    "node.d.ts",
    "native",
    "scripts",
    "wasm"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./node.d.ts",
      "import": "./node.js",
      "default": "./node.js"
    },
    "./node": {
      "types": "./node.d.ts",
      "import": "./node.js",
      "default": "./node.js"
    },
    "./browser": {
      "types": "./browser.d.ts",
      "import": "./browser.js",
      "default": "./browser.js"
    }
  },
  "scripts": {
    "task:fmt": "vp fmt",
    "task:build": "vp run build",
    "task:build-node": "vp run build-node",
    "task:build-browser": "vp run build-browser",
    "task:check": "vp run check",
    "task:package-smoke": "node ./scripts/check-package-artifacts.mjs --node --browser"
  },
  "devDependencies": {
    "vite-plus": "latest"
  }
}
